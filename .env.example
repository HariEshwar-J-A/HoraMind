# ============================================================
# HoraMind — Environment Variable Template
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
#
#   cp .env.example .env
#
# ============================================================

# ------------------------------------------------------------
# OpenRouter API Key
# Required for both LLM models (Claude + Gemini via OpenRouter)
# Get yours at: https://openrouter.ai/keys
# ------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# Telegram Bot Token
# Obtained from @BotFather on Telegram (see README.md for steps)
# Format: <numeric_id>:<alphanumeric_secret>
# Example: 7123456789:AAHdqTcvCH1vGWJxfSeofSs35NVi4jsaz38
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ------------------------------------------------------------
# ChromaDB URL
# The JyotishBase vector database endpoint.
# Default: local (same machine). Update to your VM's LAN IP if
# HoraMind runs on a different host than ChromaDB.
# Example LAN: http://192.168.1.100:8000
# ------------------------------------------------------------
CHROMA_URL=http://localhost:8000

# ------------------------------------------------------------
# Optional: Node environment
# ------------------------------------------------------------
NODE_ENV=production
